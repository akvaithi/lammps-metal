pair_style      lj/cut 2.5
pair_coeff      1 1 1.0 1.0

# harmonic bond definition supplies the equilibrium length used as the rigid
# constraint length; its stiffness is irrelevant once fix ilves constrains it
bond_style      harmonic
bond_coeff      1 200.0 0.97

neighbor        0.5 bin
neigh_modify    delay 0 every 1 check yes

# constrain every bond (type 1); print per-bond statistics every 1000 steps
fix             cstr all ilves 1.0e-4 100 500 b 1
fix             1 all nvt temp 1.0 1.0 0.5

timestep        0.005
thermo          100
thermo_style    custom step temp epair etotal press density

